{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "backend/src/app.micro.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "backend/prisma/schema.prisma"
        ]
      }
    },
    {
      "src": "api/ping.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/ping",
      "dest": "api/ping.ts"
    },
    {
      "src": "/api/(.*)",
      "dest": "backend/src/app.micro.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
