{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "backend/src/app.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "backend/prisma/schema.prisma",
          "node_modules/.prisma/client/**",
          "node_modules/@prisma/client/**"
        ]
      }
    },
    {
      "src": "backend/src/health.fn.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "backend/prisma/schema.prisma",
          "node_modules/.prisma/client/**",
          "node_modules/@prisma/client/**"
        ]
      }
    },
    {
      "src": "backend/src/auth.fn.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "backend/prisma/schema.prisma",
          "node_modules/.prisma/client/**",
          "node_modules/@prisma/client/**"
        ]
      }
    },
    {
      "src": "backend/src/chat.fn.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "backend/prisma/schema.prisma",
          "node_modules/.prisma/client/**",
          "node_modules/@prisma/client/**"
        ]
      }
    },
    {
      "src": "backend/src/tribe.fn.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "backend/prisma/schema.prisma",
          "node_modules/.prisma/client/**",
          "node_modules/@prisma/client/**"
        ]
      }
    },
    {
      "src": "backend/src/marketplace.fn.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "backend/prisma/schema.prisma",
          "node_modules/.prisma/client/**",
          "node_modules/@prisma/client/**"
        ]
      }
    },
    {
      "src": "backend/src/checkout.fn.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "backend/prisma/schema.prisma",
          "node_modules/.prisma/client/**",
          "node_modules/@prisma/client/**"
        ]
      }
    },
    {
      "src": "api/ping.ts",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/ping",
      "destination": "/api/ping.ts"
    },
    {
      "source": "/api/health",
      "destination": "/backend/src/health.fn.ts"
    },
    {
      "source": "/api/health/(.*)",
      "destination": "/backend/src/health.fn.ts"
    },
    {
      "source": "/api/auth/(.*)",
      "destination": "/backend/src/auth.fn.ts"
    },
    {
      "source": "/api/chat/(.*)",
      "destination": "/backend/src/chat.fn.ts"
    },
    {
      "source": "/api/tribe/(.*)",
      "destination": "/backend/src/tribe.fn.ts"
    },
    {
      "source": "/api/marketplace/(.*)",
      "destination": "/backend/src/marketplace.fn.ts"
    },
    {
      "source": "/api/checkout/(.*)",
      "destination": "/backend/src/checkout.fn.ts"
    },
    {
      "source": "/api/(.*)",
      "destination": "/backend/src/app.ts"
    },
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/((?!api(?:/|$)|assets(?:/|$)|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; frame-ancestors 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.sentry.io; worker-src 'self';"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}