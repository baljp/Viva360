{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "backend/src/app.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "backend/prisma/schema.prisma",
          "node_modules/.prisma/client/**",
          "node_modules/@prisma/client/**"
        ]
      }
    },
    {
      "src": "backend/src/health.fn.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "backend/prisma/schema.prisma",
          "node_modules/.prisma/client/**",
          "node_modules/@prisma/client/**"
        ]
      }
    },
    {
      "src": "backend/src/auth.fn.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "backend/prisma/schema.prisma",
          "node_modules/.prisma/client/**",
          "node_modules/@prisma/client/**"
        ]
      }
    },
    {
      "src": "backend/src/chat.fn.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "backend/prisma/schema.prisma",
          "node_modules/.prisma/client/**",
          "node_modules/@prisma/client/**"
        ]
      }
    },
    {
      "src": "api/ping.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/ping",
      "dest": "api/ping.ts"
    },
    {
      "src": "/api/health",
      "dest": "backend/src/health.fn.ts"
    },
    {
      "src": "/api/auth/(.*)",
      "dest": "backend/src/auth.fn.ts"
    },
    {
      "src": "/api/chat/(.*)",
      "dest": "backend/src/chat.fn.ts"
    },
    {
      "src": "/api/(.*)",
      "dest": "backend/src/app.ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
