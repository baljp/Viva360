{
  "name": "viva360-app",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:backend": "NODE_PATH=./backend/node_modules tsc -p backend/tsconfig.json",
    "build": "npm run prisma:generate && npm run build:backend && tsc && vite build",
    "vercel-build": "npm run prisma:generate && npm run build:backend && vite build",
    "dev:api:test": "NODE_ENV=test APP_MODE=MOCK ENABLE_TEST_MODE=true PORT=3001 npx tsx backend/src/server.ts",
    "test:audit": "npx playwright test tests/audit.spec.ts",
    "test:e2e": "npx playwright test tests/e2e_master.spec.ts",
    "test:e2e:smoke": "npx playwright test --config=playwright.smoke.config.ts",
    "test": "npx playwright test",
    "test:backend": "npx vitest run backend/src/tests",
    "test:contracts": "npx vitest run backend/src/tests/checkout.schema.test.ts backend/src/tests/interactionReceipt.service.test.ts backend/src/tests/auth.service.test.ts backend/src/tests/runtimeGuard.test.ts",
    "test:backend:security": "npx vitest run backend/src/tests/security.middleware.test.ts backend/src/tests/role.middleware.test.ts",
    "test:silent": "./verify_deployment.sh",
    "test:report": "npx playwright show-report",
    "prisma:generate": "prisma generate --schema=./backend/prisma/schema.prisma",
    "db:drift-check": "npx tsx backend/scripts/check_schema_drift.ts",
    "perf:budget": "node scripts/check_frontend_budget.cjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "test:qa": "npx playwright test --config=playwright.qa.config.ts",
    "test:qa:visual": "npx playwright test --config=playwright.qa.config.ts --project=chromium --grep @visual",
    "test:qa:stress": "npx playwright test --config=playwright.qa.config.ts --grep @stress",
    "test:endpoints": "npx ts-node backend/e2e_flow.ts",
    "test:smoke-auth": "npx tsx backend/smoke_auth.ts",
    "test:buscador-flow": "npx playwright test --config=playwright.qa.config.ts qa/flows/buscador-flow.spec.ts",
    "test:guardiao-flow": "npx playwright test --config=playwright.qa.config.ts qa/flows/guardiao-flow.spec.ts",
    "test:santuario-flow": "npx playwright test --config=playwright.qa.config.ts qa/flows/santuario-flow.spec.ts",
    "qa:audit-buttons": "npx tsx scripts/audit_buttons.ts",
    "test:debug": "npx playwright test --config=playwright.qa.config.ts qa/flows/debug-guardiao.spec.ts",
    "deploy:auto": "bash scripts/setup_vercel.sh && npx vercel --prod",
    "db:sync": "bash scripts/db_sync.sh",
    "supabase:setup": "npm run prisma:generate && npx tsx scripts/setup_db.ts",
    "supabase:verify": "npm run prisma:generate && npx tsx scripts/verify_supabase.ts",
    "supabase:test": "npx tsx scripts/test_realtime_flow.ts",
    "allowlist:add": "npx tsx backend/scripts/manage_allowlist.ts"
    ,"data:reset-mock:dry": "npx tsx backend/scripts/reset_mock_test_data.ts"
    ,"data:reset-mock": "npx tsx backend/scripts/reset_mock_test_data.ts --execute"
    ,"data:purge-profile:dry": "npx tsx backend/scripts/reset_mock_test_data.ts --purge-email=bal_19@msn.com"
    ,"data:purge-profile": "npx tsx backend/scripts/reset_mock_test_data.ts --execute --purge-email=bal_19@msn.com"
  },
  "dependencies": {
    "@faker-js/faker": "^9.9.0",
    "@opentelemetry/api": "^1.9.0",
    "@prisma/client": "^6.19.2",
    "@sentry/react": "^10.36.0",
    "@sentry/tracing": "^7.120.4",
    "@supabase/supabase-js": "^2.46.1",
    "@types/canvas-confetti": "^1.9.0",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.67.2",
    "canvas-confetti": "^1.9.4",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "framer-motion": "^11.11.17",
    "helmet": "^7.1.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.460.0",
    "morgan": "^1.10.0",
    "prisma": "^6.19.2",
    "prom-client": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.12.0",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.19.30",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vercel/node": "^5.5.30",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "terser": "^5.36.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.14.0",
    "vite": "^6.0.1",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^3.2.4"
  }
}
