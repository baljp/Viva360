// Viva360 Database Schema
// Complete production-ready schema for holistic wellness platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "file:./dev.db"
}

// Enums
enum UserRole {
  CLIENT
  PROFESSIONAL
  SPACE
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  COMPLETED
  PENDING
  FAILED
}

enum NotificationType {
  ALERT
  MESSAGE
  RITUAL
  FINANCE
  APPOINTMENT
}

enum ProductType {
  PHYSICAL
  SERVICE
  DIGITAL_CONTENT
}

enum PlantStage {
  SEED
  SPROUT
  BUD
  FLOWER
  TREE
  WITHERED
}

enum VacancyStatus {
  OPEN
  CLOSED
}

// Core User Model
model User {
  id       String   @id @default(cuid())
  email    String   @unique
  password String // hashed with bcrypt
  name     String
  role     UserRole
  avatar   String?
  bio      String?
  phone    String?

  // Gamification
  karma         Int        @default(100)
  streak        Int        @default(0)
  multiplier    Float      @default(1.0)
  plantStage    PlantStage @default(SEED)
  plantXp       Int        @default(0)
  radianceScore Int        @default(0)
  prestigeLevel Int        @default(1)
  lastCheckIn   DateTime?
  lastMood      String?
  intention     String?

  // Finances
  corporateBalance Float @default(0)
  personalBalance  Float @default(500)

  // Metadata
  isVerified Boolean   @default(false)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastLogin  DateTime?

  // Professional-specific fields
  professional Professional?

  // Space-specific fields
  space Space?

  // Relations
  appointmentsAsClient Appointment[]  @relation("ClientAppointments")
  appointmentsAsPro    Appointment[]  @relation("ProfessionalAppointments")
  transactions         Transaction[]
  notifications        Notification[]
  reviewsGiven         Review[]       @relation("ReviewAuthor")
  reviewsReceived      Review[]       @relation("ReviewRecipient")
  messagesSent         Message[]      @relation("MessageSender")
  messagesReceived     Message[]      @relation("MessageReceiver")

  // LGPD & Health Records
  patientRecords         HealthRecord[]          @relation("PatientRecords")
  professionalRecords    HealthRecord[]          @relation("ProfessionalRecords")
  consentLogs            ConsentLog[]
  notificationPreference NotificationPreference?

  // Gamification
  achievements            Achievement[]
  challengeParticipations ChallengeParticipation[]
  leaderboardEntries      LeaderboardEntry[]

  // Soul Pharmacy
  createdPills      SoulPill[]         @relation("PillCreator")
  soulPillPurchases SoulPillPurchase[]
  moodEntries       MoodEntry[]

  // Tribe
  ownedTribes    Tribe[]          @relation("TribeOwner")
  tribeMembers   TribeMember[]
  energySent     EnergyTransfer[] @relation("EnergySender")
  energyReceived EnergyTransfer[] @relation("EnergyReceiver")

  // Professional Network
  connectionsSent      ProfessionalConnection[] @relation("ConnectionRequester")
  connectionsReceived  ProfessionalConnection[] @relation("ConnectionTarget")
  swapRequestsSent     SwapRequest[]            @relation("SwapRequester")
  swapRequestsReceived SwapRequest[]            @relation("SwapTarget")
  referralsSent        Referral[]               @relation("Referrer")
  referralsReceived    Referral[]               @relation("Referred")

  // Sanctuary & Bookings
  roomBookings        RoomBooking[]
  teamMemberships     TeamMember[]
  vacancyApplications VacancyApplication[]

  // Orders
  orders        Order[]
  wishlistItems WishlistItem[]
  products      Product[]

  @@index([email])
  @@index([role])
}

// Professional Extension
model Professional {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  specialty         String // JSON: ["Yoga", "Meditação"]
  rating            Float   @default(5.0)
  reviewCount       Int     @default(0)
  pricePerSession   Float
  totalHealingHours Int     @default(0)
  location          String?
  licenseNumber     String?

  // Swap & Network
  swapCredits        Int     @default(0)
  isAvailableForSwap Boolean @default(false)
  offers             String  @default("[]")
  needs              String  @default("[]")

  // Hub association
  spaceId String?
  space   Space?  @relation("SpaceTeam", fields: [spaceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId])
}

// Space Extension
model Space {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  spaceName String
  address   String?
  city      String?
  capacity  Int     @default(0)
  amenities String  @default("[]")

  // Team Management
  team Professional[] @relation("SpaceTeam")

  // Rooms
  rooms Room[]

  // Vacancies
  vacancies Vacancy[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  teamMembers TeamMember[]
}

// Room Model
model Room {
  id              String  @id @default(cuid())
  name            String
  status          String  @default("available") // available, occupied
  currentOccupant String?

  spaceId String
  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  roomBookings RoomBooking[]

  @@index([spaceId])
}

// Appointment Model
model Appointment {
  id String @id @default(cuid())

  clientId String
  client   User   @relation("ClientAppointments", fields: [clientId], references: [id], onDelete: Cascade)

  professionalId String
  professional   User   @relation("ProfessionalAppointments", fields: [professionalId], references: [id], onDelete: Cascade)

  serviceName String
  price       Float
  date        DateTime
  time        String
  status      AppointmentStatus @default(PENDING)

  // Session details
  notes       String?
  duration    Int     @default(60) // minutes
  videoRoomId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([professionalId])
  @@index([date])
  @@index([status])
}

// Transaction Model
model Transaction {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        TransactionType
  amount      Float
  description String
  status      TransactionStatus @default(COMPLETED)

  // Metadata
  reference     String? // appointment ID, product ID, etc.
  paymentMethod String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// Notification Model
model Notification {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType
  title   String
  message String
  read    Boolean          @default(false)

  // Action link
  actionUrl String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

// Product/Marketplace Model
model Product {
  id          String      @id @default(cuid())
  name        String
  description String?
  price       Float
  image       String?
  category    String
  type        ProductType

  // Inventory
  stock    Int     @default(0)
  isActive Boolean @default(true)

  // Seller
  sellerId String?
  seller   User?   @relation(fields: [sellerId], references: [id], onDelete: SetNull)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  wishlistItems WishlistItem[]

  @@index([category])
  @@index([type])
  @@index([isActive])
  @@index([sellerId])
}

// Review Model
model Review {
  id String @id @default(cuid())

  authorId String
  author   User   @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  recipientId String
  recipient   User   @relation("ReviewRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  rating  Int // 1-5
  comment String?
  tags    String  @default("[]")

  // Context
  appointmentId String?

  createdAt DateTime @default(now())

  @@index([recipientId])
  @@index([authorId])
  @@index([rating])
}

// Message/Chat Model
model Message {
  id String @id @default(cuid())

  senderId String
  sender   User   @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  receiverId String
  receiver   User   @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  content String
  read    Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

// Vacancy Model (for Space recruitment)
model Vacancy {
  id String @id @default(cuid())

  spaceId String
  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  title           String
  description     String
  specialties     String
  status          VacancyStatus @default(OPEN)
  applicantsCount Int           @default(0)

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  vacancyApplications VacancyApplication[]

  @@index([spaceId])
  @@index([status])
}

// ====================================
// PHASE 1: LGPD & Notifications
// ====================================

// Health Record (Prontuário) - LGPD Compliant
model HealthRecord {
  id String @id @default(cuid())

  patientId String
  patient   User   @relation("PatientRecords", fields: [patientId], references: [id], onDelete: Cascade)

  professionalId String
  professional   User   @relation("ProfessionalRecords", fields: [professionalId], references: [id], onDelete: Cascade)

  title       String
  content     String // Encrypted content
  category    String // consulta, evolucao, prescricao, exame
  isEncrypted Boolean @default(true)

  // LGPD Sharing
  isShared     Boolean   @default(false)
  shareType    String    @default("NONE") // NONE, SPECIFIC, ALL_MY_PROS
  sharedWith   String    @default("[]") // JSON array of user IDs
  consentGiven Boolean   @default(false)
  consentDate  DateTime?
  expiresAt    DateTime?

  // Soft delete for LGPD compliance
  isDeleted  Boolean   @default(false)
  deletedAt  DateTime?
  anonymized Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([professionalId])
  @@index([category])
  @@index([isShared])
}

// Consent Log (Audit trail for LGPD)
model ConsentLog {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  recordId String? // HealthRecord ID if applicable
  action   String // GRANT, REVOKE, VIEW, DOWNLOAD, DELETE, EXPORT
  targetId String? // Who received/lost access
  details  String? // Additional context

  ipAddress String?
  userAgent String?

  timestamp DateTime @default(now())

  @@index([userId])
  @@index([recordId])
  @@index([action])
  @@index([timestamp])
}

// Notification Preferences
model NotificationPreference {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // By type
  appointments Boolean @default(true)
  messages     Boolean @default(true)
  health       Boolean @default(true)
  gamification Boolean @default(true)
  ritual       Boolean @default(true)
  marketplace  Boolean @default(true)
  tribe        Boolean @default(true)
  system       Boolean @default(true)

  // Channels
  pushEnabled  Boolean @default(true)
  emailEnabled Boolean @default(true)
  smsEnabled   Boolean @default(false)

  // Email digest
  emailDigest String  @default("INSTANT") // INSTANT, DAILY, WEEKLY, NONE
  quietStart  String? // "22:00"
  quietEnd    String? // "08:00"

  updatedAt DateTime @updatedAt
}

// ====================================
// PHASE 2: Gamification
// ====================================

// Achievement / Badge
model Achievement {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  badgeId     String
  badgeName   String
  badgeIcon   String
  description String
  rarity      String @default("COMMON") // COMMON, RARE, EPIC, LEGENDARY
  category    String // STREAK, SESSIONS, MEDITATION, SOCIAL, SPECIAL

  progress    Int      @default(100)
  unlockedAt  DateTime @default(now())
  karmaReward Int      @default(0)

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([category])
}

// Challenge
model Challenge {
  id String @id @default(cuid())

  type        String // DAILY, WEEKLY, MONTHLY, SPECIAL
  title       String
  description String
  icon        String?
  target      Int // Target value to complete
  reward      Int // Karma reward
  badgeId     String? // Badge awarded on completion

  category String // MEDITATION, CHECK_IN, SESSIONS, SOCIAL
  isActive Boolean @default(true)

  startsAt DateTime
  endsAt   DateTime

  createdAt               DateTime                 @default(now())
  challengeParticipations ChallengeParticipation[]

  @@index([type])
  @@index([isActive])
  @@index([startsAt])
}

// Challenge Participation
model ChallengeParticipation {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  progress    Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?

  joinedAt DateTime @default(now())

  @@unique([userId, challengeId])
  @@index([userId])
  @@index([challengeId])
}

// Leaderboard Entry
model LeaderboardEntry {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  period   String // WEEKLY, MONTHLY, ALL_TIME
  category String // KARMA, SESSIONS, STREAK, MEDITATION

  score Int
  rank  Int?

  updatedAt DateTime @updatedAt

  @@unique([userId, period, category])
  @@index([period])
  @@index([category])
  @@index([score])
}

// ====================================
// PHASE 3: Soul Pharmacy
// ====================================

// Soul Pill (Infoproduto)
model SoulPill {
  id String @id @default(cuid())

  creatorId String
  creator   User   @relation("PillCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  title        String
  description  String
  type         String // AUDIO, VIDEO, TEXT, GUIDED_MEDITATION, COURSE
  contentUrl   String
  thumbnailUrl String?
  duration     Int? // Duration in minutes

  // Mood targeting
  targetMoods String @default("[]") // JSON array: ["SERENO", "ANSIOSO"]

  // Pricing
  price    Float   @default(0)
  isFree   Boolean @default(false)
  currency String  @default("BRL")

  // Stats
  views       Int   @default(0)
  purchases   Int   @default(0)
  avgRating   Float @default(5)
  reviewCount Int   @default(0)

  // Status
  isPublished Boolean @default(false)
  isFeatured  Boolean @default(false)

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  soulPillPurchases SoulPillPurchase[]

  @@index([creatorId])
  @@index([type])
  @@index([isFree])
  @@index([isFeatured])
}

// Soul Pill Purchase
model SoulPillPurchase {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  pillId String
  pill   SoulPill @relation(fields: [pillId], references: [id], onDelete: Cascade)

  pricePaid     Float
  accessGranted DateTime  @default(now())
  accessExpires DateTime?

  // Progress tracking
  progress     Int       @default(0) // 0-100%
  lastAccessed DateTime?
  completed    Boolean   @default(false)

  @@unique([userId, pillId])
  @@index([userId])
  @@index([pillId])
}

// Mood Entry with Photo
model MoodEntry {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  mood        String // SERENO, VIBRANTE, MELANCÓLICO, ANSIOSO, FOCADO, EXAUSTO, GRATO
  intensity   Int     @default(3) // 1-5
  notes       String?
  photoUrl    String? // Selfie from ritual
  photoFilter String? // Filter applied

  // Suggestions
  suggestedPills String @default("[]") // JSON array of pill IDs

  // Context
  isRitualEntry  Boolean @default(false)
  ritualComplete Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([mood])
  @@index([createdAt])
}

// ====================================
// PHASE 4: Tribe
// ====================================

// Tribe (Circle of Trust)
model Tribe {
  id String @id @default(cuid())

  ownerId String
  owner   User   @relation("TribeOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  name        String
  description String?
  maxMembers  Int     @default(7)
  isPublic    Boolean @default(false)

  // Stats
  totalKarma  Int @default(0)
  weeklyKarma Int @default(0)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  tribeMembers TribeMember[]

  @@index([ownerId])
}

// Tribe Membership
model TribeMember {
  id String @id @default(cuid())

  tribeId String
  tribe   Tribe  @relation(fields: [tribeId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role     String   @default("MEMBER") // OWNER, ELDER, MEMBER
  joinedAt DateTime @default(now())

  // Engagement
  energySent     Int @default(0)
  energyReceived Int @default(0)

  @@unique([tribeId, userId])
  @@index([tribeId])
  @@index([userId])
}

// Energy Transfer (Karma between tribe members)
model EnergyTransfer {
  id String @id @default(cuid())

  senderId String
  sender   User   @relation("EnergySender", fields: [senderId], references: [id], onDelete: Cascade)

  receiverId String
  receiver   User   @relation("EnergyReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  amount  Int
  message String?

  createdAt DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
}

// ====================================
// PHASE 5: Professional Network
// ====================================

// Professional Connection
model ProfessionalConnection {
  id String @id @default(cuid())

  requesterId String
  requester   User   @relation("ConnectionRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  targetId String
  target   User   @relation("ConnectionTarget", fields: [targetId], references: [id], onDelete: Cascade)

  status  String  @default("PENDING") // PENDING, ACCEPTED, REJECTED
  message String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([requesterId, targetId])
  @@index([requesterId])
  @@index([targetId])
  @@index([status])
}

// Swap Request (Service Exchange)
model SwapRequest {
  id String @id @default(cuid())

  requesterId String
  requester   User   @relation("SwapRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  targetId String
  target   User   @relation("SwapTarget", fields: [targetId], references: [id], onDelete: Cascade)

  offerService   String
  requestService String
  offerHours     Float
  requestHours   Float

  status String  @default("PENDING") // PENDING, ACCEPTED, COMPLETED, CANCELLED
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requesterId])
  @@index([targetId])
  @@index([status])
}

// Referral
model Referral {
  id String @id @default(cuid())

  referrerId String
  referrer   User   @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)

  referredId String
  referred   User   @relation("Referred", fields: [referredId], references: [id], onDelete: Cascade)

  patientId   String?
  patientName String?
  notes       String?

  status String @default("PENDING") // PENDING, CONVERTED, EXPIRED
  reward Int    @default(0)

  createdAt DateTime @default(now())

  @@index([referrerId])
  @@index([referredId])
}

// ====================================
// PHASE 6: Sanctuary Management
// ====================================

// Room Booking
model RoomBooking {
  id String @id @default(cuid())

  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date      DateTime
  startTime String
  endTime   String
  duration  Int // minutes

  price  Float
  status String @default("CONFIRMED") // CONFIRMED, CANCELLED, COMPLETED

  createdAt DateTime @default(now())

  @@index([roomId])
  @@index([userId])
  @@index([date])
}

// Team Member (Enhanced)
model TeamMember {
  id String @id @default(cuid())

  spaceId String
  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role           String    @default("PROFESSIONAL") // PROFESSIONAL, ADMIN, RECEPTIONIST
  commissionRate Float     @default(0.7) // 70% default
  contractType   String? // CLT, PJ, PARTNER
  startDate      DateTime  @default(now())
  endDate        DateTime?

  // Performance
  totalSessions Int   @default(0)
  totalRevenue  Float @default(0)
  avgRating     Float @default(5)

  isActive Boolean @default(true)

  @@unique([spaceId, userId])
  @@index([spaceId])
  @@index([userId])
}

// Vacancy Application
model VacancyApplication {
  id String @id @default(cuid())

  vacancyId String
  vacancy   Vacancy @relation(fields: [vacancyId], references: [id], onDelete: Cascade)

  applicantId String
  applicant   User   @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  coverLetter String?
  resumeUrl   String?

  status     String  @default("PENDING") // PENDING, REVIEWING, INTERVIEW, ACCEPTED, REJECTED
  matchScore Int? // Algorithm calculated match
  notes      String?

  appliedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([vacancyId, applicantId])
  @@index([vacancyId])
  @@index([applicantId])
  @@index([status])
}

// ====================================
// PHASE 7: Orders & Checkout
// ====================================

// Order
model Order {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type   String // PRODUCT, SERVICE, SOUL_PILL, SUBSCRIPTION
  status String @default("PENDING") // PENDING, PAID, PROCESSING, SHIPPED, DELIVERED, CANCELLED

  subtotal Float
  discount Float @default(0)
  total    Float

  // Payment
  paymentMethod String? // PIX, CREDIT_CARD, BALANCE
  paymentId     String? // External payment ID
  paidAt        DateTime?

  // Shipping (for physical products)
  shippingAddress String?
  shippingCost    Float   @default(0)
  trackingCode    String?

  // Coupon
  couponCode String?

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  orderItems OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([type])
}

// Order Item
model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId   String?
  productName String
  productType String // PRODUCT, SERVICE, SOUL_PILL
  quantity    Int     @default(1)
  unitPrice   Float
  totalPrice  Float

  // For services
  appointmentId String?

  @@index([orderId])
}

// Coupon
model Coupon {
  id String @id @default(cuid())

  code        String  @unique
  description String?
  type        String // PERCENTAGE, FIXED
  value       Float // 10 for 10% or R$10
  minPurchase Float?

  usageLimit Int?
  usageCount Int       @default(0)
  expiresAt  DateTime?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  @@index([code])
  @@index([isActive])
}

// Wishlist
model WishlistItem {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  addedAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}
