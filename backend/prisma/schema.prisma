generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "auth"]
}

// --------------------------------------------------------
// Auth Schema (Vanilla Postgres Simulation for Supabase)
// --------------------------------------------------------
model User {
  instance_id        String?   @db.Uuid
  id                 String    @id @default(uuid()) @db.Uuid
  email              String?   @unique
  encrypted_password String?
  aud                String?
  role               String?
  email_confirmed_at DateTime? @db.Timestamptz(6)
  last_sign_in_at    DateTime? @db.Timestamptz(6)
  raw_app_meta_data  Json?
  raw_user_meta_data Json?

  // Relations
  profile Profile?

  // Timestamps
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @updatedAt @db.Timestamptz(6)

  @@map("users")
  @@schema("auth")
}

// --------------------------------------------------------
// Public Schema
// --------------------------------------------------------

model Profile {
  id                String   @id @db.Uuid
  email             String?
  name              String?
  role              String? // 'CLIENT', 'PROFESSIONAL', 'SPACE'
  avatar            String?
  bio               String?
  karma             Int      @default(0)
  streak            Int      @default(0)
  multiplier        Decimal  @default(1)
  personal_balance  Decimal  @default(0)
  corporate_balance Decimal  @default(0)
  plant_xp          Int      @default(0)
  plant_stage       String   @default("seed")
  location          String?
  specialty         String[] @default([])
  hub_id            String?  @db.Uuid
  rating            Decimal  @default(5.0)
  review_count      Int      @default(0)
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  // Relations
  user                   User           @relation(fields: [id], references: [id], onDelete: Cascade)
  appointments_as_client Appointment[]  @relation("ClientAppointments")
  appointments_as_pro    Appointment[]  @relation("ProAppointments")
  transactions           Transaction[]
  notifications          Notification[]
  products               Product[]

  // Rooms/Vacancies (simplification: generic ownership)
  // Rooms/Vacancies
  rooms Room[]

  // New Features Relations
  sent_messages     ChatMessage[]   @relation("SentMessages")
  received_messages ChatMessage[]   @relation("ReceivedMessages")
  swap_provided     SwapOffer[]     @relation("SwapProvider")
  swap_requested    SwapOffer[]     @relation("SwapRequester")
  tribe_invites     TribeInvite[]   @relation("HubInvites")
  calendar_events   CalendarEvent[]
  vacancies         Vacancy[]

  // Records Relations
  patient_records      Record[]           @relation("PatientRecords")
  professional_records Record[]           @relation("ProfessionalRecords")
  oracleHistories      OracleHistory[]
  guardianPresences    GuardianPresence[]

  // Profile Links Relations
  source_links ProfileLink[] @relation("SourceLinks")
  target_links ProfileLink[] @relation("TargetLinks")

  // Chat Participants
  chat_participations ChatParticipant[]

  // Marketplace Orders
  buyer_orders  MarketplaceOrder[] @relation("BuyerOrders")
  seller_orders MarketplaceOrder[] @relation("SellerOrders")

  // Escambo Proposals
  proposer_escambos EscamboProposal[] @relation("ProposerEscambo")
  receiver_escambos EscamboProposal[] @relation("ReceiverEscambo")

  @@map("profiles")
  @@schema("public") // Prisma default is public but explicit is better
}

model AuthAllowlist {
  id         String    @id @default(uuid()) @db.Uuid
  email      String    @unique
  role       String?
  status     String    @default("APPROVED")
  invited_by String?   @db.Uuid
  used_by    String?   @db.Uuid
  notes      String?
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  used_at    DateTime? @db.Timestamptz(6)

  @@map("auth_allowlist")
  @@schema("public")
}

model Appointment {
  id                String   @id @default(uuid()) @db.Uuid
  client_id         String?  @db.Uuid
  professional_id   String?  @db.Uuid
  service_name      String
  professional_name String?
  client_name       String?
  date              DateTime @db.Timestamptz(6)
  time              String
  price             Decimal
  status            String   @default("pending")
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  client       Profile? @relation("ClientAppointments", fields: [client_id], references: [id])
  professional Profile? @relation("ProAppointments", fields: [professional_id], references: [id])

  @@map("appointments")
  @@schema("public")
}

model Product {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  price       Decimal
  image       String?
  category    String?
  type        String?
  description String?
  owner_id    String?  @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  owner             Profile?           @relation(fields: [owner_id], references: [id])
  marketplaceOrders MarketplaceOrder[]

  @@map("products")
  @@schema("public")
}

model Transaction {
  id          String   @id @default(uuid()) @db.Uuid
  user_id     String   @db.Uuid
  type        String?
  amount      Decimal
  description String?
  status      String?  @default("completed")
  date        DateTime @default(now()) @db.Timestamptz(6)

  user Profile @relation(fields: [user_id], references: [id])

  @@map("transactions")
  @@schema("public")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  user_id   String   @db.Uuid
  type      String?
  title     String
  message   String
  read      Boolean  @default(false)
  timestamp DateTime @default(now()) @db.Timestamptz(6)

  user Profile @relation(fields: [user_id], references: [id])

  @@map("notifications")
  @@schema("public")
}

model Room {
  id               String   @id @default(uuid()) @db.Uuid
  hub_id           String   @db.Uuid
  name             String
  status           String   @default("available")
  current_occupant String?
  created_at       DateTime @default(now()) @db.Timestamptz(6)

  hub Profile @relation(fields: [hub_id], references: [id])

  @@map("rooms")
  @@schema("public")
}

model ChatMessage {
  id          String   @id @default(uuid()) @db.Uuid
  chat_id     String?  @db.Uuid
  sender_id   String   @db.Uuid
  receiver_id String   @db.Uuid
  content     String
  read        Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  chat     Chat?   @relation(fields: [chat_id], references: [id])
  sender   Profile @relation("SentMessages", fields: [sender_id], references: [id])
  receiver Profile @relation("ReceivedMessages", fields: [receiver_id], references: [id])

  @@map("chat_messages")
  @@schema("public")
}

model SwapOffer {
  id                String   @id @default(uuid()) @db.Uuid
  provider_id       String   @db.Uuid
  requester_id      String   @db.Uuid
  offered_item_id   String?  @db.Uuid
  requested_item_id String?  @db.Uuid
  description       String?
  status            String   @default("pending")
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  provider  Profile @relation("SwapProvider", fields: [provider_id], references: [id])
  requester Profile @relation("SwapRequester", fields: [requester_id], references: [id])

  @@map("swap_offers")
  @@schema("public")
}

model TribeInvite {
  id         String   @id @default(uuid()) @db.Uuid
  hub_id     String   @db.Uuid
  email      String
  token      String   @unique
  status     String   @default("pending")
  created_at DateTime @default(now()) @db.Timestamptz(6)

  hub Profile @relation("HubInvites", fields: [hub_id], references: [id])

  @@map("tribe_invites")
  @@schema("public")
}

model CalendarEvent {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  title      String
  start_time DateTime @db.Timestamptz(6)
  end_time   DateTime @db.Timestamptz(6)
  type       String?
  details    String?
  created_at DateTime @default(now()) @db.Timestamptz(6)

  user Profile @relation(fields: [user_id], references: [id])

  @@map("calendar_events")
  @@schema("public")
}

model Vacancy {
  id          String   @id @default(uuid()) @db.Uuid
  space_id    String   @db.Uuid
  title       String
  description String
  specialties String[]
  status      String   @default("open")
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  space Profile @relation(fields: [space_id], references: [id])

  @@map("vacancies")
  @@schema("public")
}

model Record {
  id              String   @id @default(uuid()) @db.Uuid
  patient_id      String   @db.Uuid
  professional_id String   @db.Uuid
  content         String
  type            String // 'anamnesis' | 'session'
  created_at      DateTime @default(now()) @db.Timestamptz(6)

  patient      Profile @relation("PatientRecords", fields: [patient_id], references: [id])
  professional Profile @relation("ProfessionalRecords", fields: [professional_id], references: [id])

  @@map("records")
  @@schema("public")
}

// --------------------------------------------------------
// Distributed Systems Schema (Phase 3)
// --------------------------------------------------------

model Event {
  id         String   @id @default(uuid()) @db.Uuid
  stream_id  String   @db.Uuid // Usually userId or EntityId
  type       String // e.g., 'MOOD_LOGGED'
  payload    Json
  version    Int      @default(1)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([stream_id])
  @@map("events")
  @@schema("public")
}

model MetamorphosisProjection {
  user_id         String   @id @db.Uuid
  total_checkins  Int      @default(0)
  last_mood       String?
  streak_days     Int      @default(0)
  evolution_score Int      @default(0)
  last_updated_at DateTime @default(now()) @db.Timestamptz(6)

  @@map("metamorphosis_projections")
  @@schema("public")
}

model OracleMessage {
  id              String          @id @default(uuid()) @db.Uuid
  text            String
  category        String // cura_emocional, consciencia, acao_foco, etc.
  element         String // Fogo, Agua, Terra, Ar
  moods           String[] // Array of moods (e.g., ['ansioso', 'triste'])
  phases          String[] // Array of metamorphosis phases
  depth           Int             @default(1)
  weight          Decimal         @default(1.0)
  rarity          String          @default("common") // common, rare, epic
  created_at      DateTime        @default(now()) @db.Timestamptz(6)
  oracleHistories OracleHistory[]

  @@map("oracle_messages")
  @@schema("public")
}

model OracleHistory {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  message_id String   @db.Uuid
  drawn_at   DateTime @default(now()) @db.Timestamptz(6)
  context    Json // Stores context at draw time (mood, garden status, etc)

  // Relations
  user    Profile       @relation(fields: [user_id], references: [id])
  message OracleMessage @relation(fields: [message_id], references: [id])

  @@map("oracle_history")
  @@schema("public")
}

model GuardianPresence {
  guardian_id      String   @id @db.Uuid
  status           String   @default("OFFLINE") // ONLINE, OFFLINE, BUSY
  last_activity_at DateTime @default(now()) @db.Timestamptz(6)
  expires_at       DateTime @db.Timestamptz(6)

  guardian Profile @relation(fields: [guardian_id], references: [id], onDelete: Cascade)

  @@map("guardian_presence")
  @@schema("public")
}

// --------------------------------------------------------
// Profile Linking System (Vínculos)
// --------------------------------------------------------

model ProfileLink {
  id         String   @id @default(uuid()) @db.Uuid
  source_id  String   @db.Uuid
  target_id  String   @db.Uuid
  type       String // 'tribo' | 'paciente' | 'escambo' | 'equipe' | 'bazar'
  status     String   @default("pending") // 'pending' | 'accepted' | 'active'
  created_at DateTime @default(now()) @db.Timestamptz(6)

  source Profile @relation("SourceLinks", fields: [source_id], references: [id])
  target Profile @relation("TargetLinks", fields: [target_id], references: [id])

  @@unique([source_id, target_id, type])
  @@map("profile_links")
  @@schema("public")
}

// --------------------------------------------------------
// Chat Rooms (Context-aware)
// --------------------------------------------------------

model Chat {
  id         String   @id @default(uuid()) @db.Uuid
  type       String // 'private' | 'escambo' | 'agendamento' | 'bazar'
  context_id String?  @db.Uuid // Reference to escambo/appointment/order
  created_at DateTime @default(now()) @db.Timestamptz(6)

  participants ChatParticipant[]
  messages     ChatMessage[]

  @@map("chats")
  @@schema("public")
}

model ChatParticipant {
  id           String   @id @default(uuid()) @db.Uuid
  chat_id      String   @db.Uuid
  profile_id   String   @db.Uuid
  unread_count Int      @default(0)
  joined_at    DateTime @default(now()) @db.Timestamptz(6)

  chat    Chat    @relation(fields: [chat_id], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profile_id], references: [id])

  @@unique([chat_id, profile_id])
  @@map("chat_participants")
  @@schema("public")
}

// --------------------------------------------------------
// Marketplace Orders
// --------------------------------------------------------

model MarketplaceOrder {
  id          String   @id @default(uuid()) @db.Uuid
  buyer_id    String   @db.Uuid
  seller_id   String   @db.Uuid
  product_id  String   @db.Uuid
  quantity    Int      @default(1)
  total_price Decimal
  status      String   @default("pending") // 'pending' | 'paid' | 'shipped' | 'completed'
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  buyer   Profile @relation("BuyerOrders", fields: [buyer_id], references: [id])
  seller  Profile @relation("SellerOrders", fields: [seller_id], references: [id])
  product Product @relation(fields: [product_id], references: [id])

  @@map("marketplace_orders")
  @@schema("public")
}

// --------------------------------------------------------
// Escambo Proposals (Swap System)
// --------------------------------------------------------

model EscamboProposal {
  id          String   @id @default(uuid()) @db.Uuid
  proposer_id String   @db.Uuid
  receiver_id String   @db.Uuid
  offer       String // What proposer offers
  request     String // What proposer wants
  status      String   @default("pending") // 'pending' | 'accepted' | 'rejected' | 'completed'
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  proposer Profile @relation("ProposerEscambo", fields: [proposer_id], references: [id])
  receiver Profile @relation("ReceiverEscambo", fields: [receiver_id], references: [id])

  @@map("escambo_proposals")
  @@schema("public")
}

// --------------------------------------------------------
// Audit Events (Event Sourcing Light)
// --------------------------------------------------------

model AuditEvent {
  id          String   @id @default(uuid()) @db.Uuid
  actor_id    String   @db.Uuid
  action      String // 'link.created' | 'chat.sent' | 'appointment.created' etc.
  entity_type String // 'profile_link' | 'chat' | 'appointment'
  entity_id   String   @db.Uuid
  payload     Json?
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  @@index([actor_id])
  @@index([entity_type, entity_id])
  @@map("audit_events")
  @@schema("public")
}
