{
  "name": "viva360-backend",
  "version": "1.0.0",
  "description": "Enterprise-grade Node.js backend for Viva360",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev -r dotenv/config --respawn --transpile-only src/server.ts",
    "dev:auth": "ts-node-dev -r dotenv/config --respawn --transpile-only src/server-auth.ts",
    "dev:ritual": "ts-node-dev -r dotenv/config --respawn --transpile-only src/server-ritual.ts",
    "dev:oracle": "ts-node-dev -r dotenv/config --respawn --transpile-only src/server-oracle.ts",
    "dev:marketplace": "ts-node-dev -r dotenv/config --respawn --transpile-only src/server-marketplace.ts",
    "dev:notification": "ts-node-dev -r dotenv/config --respawn --transpile-only src/server-notification.ts",
    "dev:worker": "ts-node-dev -r dotenv/config --respawn --transpile-only src/worker.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts",
    "test": "jest"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.69.0",
    "@opentelemetry/sdk-node": "^0.211.0",
    "@prisma/client": "^6.19.2",
    "@supabase/supabase-js": "^2.39.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.66.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "prisma": "^6.19.2",
    "prom-client": "^15.1.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/ioredis": "^4.28.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "eslint": "^8.54.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  }
}
