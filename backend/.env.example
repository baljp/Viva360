PORT=3000
DATABASE_URL="postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase Keys (Required for Auth & Rewards)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here-REQUIRED-FOR-REWARDS
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres"

# Optional: Read Replica (Enterprise Scale)
DATABASE_URL_READ_REPLICA="postgresql://postgres:[PASSWORD]@replica.db.[PROJECT_ID].supabase.co:5432/postgres"

# Analytics & Observability
OTEL_EXPORTER_OTLP_ENDPOINT="https://api.honeycomb.io"
OTEL_EXPORTER_OTLP_HEADERS='{"x-honeycomb-team": "YOUR_API_KEY"}'

# Asset Optimization
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Mode
MOCK_MODE=false
APP_MODE=production
ENABLE_TEST_MODE=false

# Security
JWT_SECRET="change-me-in-prod"

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS="http://localhost:5173"

# Metrics (required in production to access /metrics)
METRICS_TOKEN="set-a-strong-token"

