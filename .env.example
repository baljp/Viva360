# Supabase Configuration
VITE_SUPABASE_URL=https://<your-project>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# Application Mode (MOCK, DEMO, PROD)
# Set to 'PROD' to enable Real Supabase Auth & Data
VITE_APP_MODE=PROD

# Database Connection (Required for 'npm run supabase:setup')
# Get this from Supabase Dashboard > Settings > Database > Connection String
# Format: postgresql://postgres.<user>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=
