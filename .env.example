# --- CORE CONFIGURATION ---
# Supabase Project URL (Frontend & Backend)
VITE_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co
# Supabase Public Anonymous Key (Frontend & Backend)
VITE_SUPABASE_ANON_KEY=your-anon-key
# Supabase Service Role Key (BACKEND ONLY - DO NOT EXPOSE TO FRONTEND)
# Required for bypassing RLS during registration/admin tasks
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Application Mode: production | staging | mock (legacy aliases PROD/MOCK/DEMO are still accepted)
VITE_APP_MODE=production
APP_MODE=production
ENABLE_TEST_MODE=false
VITE_ENABLE_TEST_MODE=false

# DATA-01: Unified mock control flag — single source of truth for mock mode.
# Set to 'true' ONLY in local dev / CI. Never in production or staging.
MOCK_ENABLED=false
VITE_MOCK_ENABLED=false

# SEC-01: Mock auth token — read from env, never hardcoded in source.
# Generate a unique token per environment. Leave empty in production.
# Example: openssl rand -hex 24
MOCK_AUTH_TOKEN=
VITE_MOCK_AUTH_TOKEN=

# Security
JWT_SECRET=change-me-in-production

# OAuth Redirect URL used by Google login via Supabase Auth.
# Must be whitelisted in Supabase Authentication > URL Configuration > Redirect URLs
# Local example: http://localhost:5173/login
# Production example: https://app.seudominio.com/login
VITE_SUPABASE_AUTH_REDIRECT_URL=http://localhost:5173/login
# Explicit allowlist for OAuth redirect origins (comma-separated).
# Example: http://localhost:5173,https://viva360.vercel.app
VITE_OAUTH_ALLOWED_ORIGINS=http://localhost:5173

# CORS Configuration: List of allowed frontend domains (Comma-separated)
# Example: http://localhost:5173,https://viva360.vercel.app
CORS_ORIGINS=http://localhost:5173

# --- DATABASE CONNECTION ---
# Used for backend API and migrations (Supabase Pooler is recommended)
# Get from Supabase > Settings > Database > Connection String
DATABASE_URL="postgresql://postgres.user:password@aws-0-pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.user:password@aws-0-db.supabase.com:5432/postgres"

# --- FEATURE SPECIFIC (OPTIONAL) ---
# Stripe for Payments
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=

# Resend for Email notifications
RESEND_API_KEY=

# Cloudinary for Image uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Redis for Queues/Caching (defaults to localhost:6379)
REDIS_HOST=localhost
REDIS_PORT=6379

# API URL (Frontend) - Defaults to /api
VITE_API_URL=/api

# Chaos Engineering mode (true/false)
# Chaos Engineering mode (true/false)
CHAOS_MODE=false

# --- TIMELAPSE FEATURE ---
# Background audio URL for the TimeLapse evolution video feature.
# Leave empty for silence (recommended for production). Use a hosted .mp3 URL for dev.
# Example: https://your-cdn.com/zen-432hz.mp3
VITE_TIMELAPSE_AUDIO_URL=

